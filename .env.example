# Auth (required for login)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
DATABASE_URL="file:./prisma/dev.db"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# How to pull LinkedIn data (same public metrics CGA used: reactions, comments, reposts)
#
# apify   — live public company posts via Apify (no LinkedIn login needed)
# linkedin — official LinkedIn Marketing API (requires client OAuth)
# seed    — curated research corpus (what CGA actually shipped in their demo)

LINKEDIN_DATA_PROVIDER=apify
LINKEDIN_COMPANY_SLUG=beonemedicines
LINKEDIN_MAX_POSTS=30

# Apify: https://console.apify.com/account/integrations
APIFY_TOKEN=

# Multi-channel social sync (Instagram, Facebook, X, YouTube)
SOCIAL_INSTAGRAM_HANDLE=beonemedicines
SOCIAL_FACEBOOK_URL=https://www.facebook.com/BeOneMeds/
SOCIAL_X_HANDLE=BeOneMedicines
SOCIAL_YOUTUBE_CHANNEL=@beonemedicines
SOCIAL_MAX_POSTS_PER_CHANNEL=50

# Official LinkedIn API (optional)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_API_VERSION=202505

# Pfizer demo URL linked from the VibeCodeFlow marketing site
NEXT_PUBLIC_PFIZER_DEMO_URL=https://pfizer.vibecodeflow.com
